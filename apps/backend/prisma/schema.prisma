generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Usuario {
  cedula String @id

  primer_nombre  String
  segundo_nombre String? // Opcional

  primer_apellido  String
  segundo_apellido String? // Opcional

  // Datos personales
  email    String  @unique
  telefono String?

  // Informacion de la cuenta
  permisos  String @default("0") // array serializado: "0,1,2"
  pass_hash String

  // Informacion de tiempos
  creado_at      DateTime @default(now())
  actualizado_at DateTime @updatedAt

  // Noticias subidas por usuario
  noticias Noticia[]

  // Recursos subidos por el usuario
  recursos Recurso[]
}

model Noticia {
  id          Int      @id @default(autoincrement())
  titulo      String
  descripcion String
  publicado   DateTime @default(now())

  // Relaciones
  usuario       Usuario @relation(fields: [usuarioCedula], references: [cedula])
  usuarioCedula String

  recursos Recurso[] // una noticia puede no tener recursos

  @@index([id])
}

model Recurso {
  id       Int    @id @default(autoincrement())
  resource String

  // Datos
  fecha      DateTime @default(now())
  es_noticia Boolean  @default(false)

  // Relacion
  noticia   Noticia? @relation(fields: [noticiaId], references: [id])
  noticiaId Int?

  usuario       Usuario @relation(fields: [usuarioCedula], references: [cedula])
  usuarioCedula String
}

// Tabla temporal KV
model Session {
  key         String   @id
  value       Json
  creado_at   DateTime @default(now())
  vencimiento DateTime

  @@index([vencimiento])
}
