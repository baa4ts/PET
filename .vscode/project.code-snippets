        "prefix": "route-init",
        "body": [
            "import { Request, Response, Router } from \"express\";",
            "",
            "/**",
            " * Instancia",
            " */",
            "const API = Router();",
            "",
            "",
            "/**",
            " * Exports",
            " */",
            "export { API as Route${1:Nombre} };"
        ]
    },
